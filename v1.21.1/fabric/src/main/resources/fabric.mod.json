{
  "schemaVersion": 1,
  "id": "sce",
  "version": "${version}",
  "name": "Simple Craft Editor",
  "description": "In-game editor for vanilla and modded crafting recipes.",
  "authors": [
    "MateoF24"
  ],
  "contact": {
    "homepage": "https://github.com/MateoF024/SimpleCraftEditor"
  },
  "license": "LicenseRef-SimpleCraftEditor (see LICENSE-sce.txt)",
  "icon": "assets/sce/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "org.mateof24.sce.fabric.SimpleCraftEditorFabric"
    ],
    "client": [
      "org.mateof24.sce.fabric.client.SimpleCraftEditorFabricClient"
    ],
    "jei_mod_plugin": [
      "org.mateof24.sce.client.jei.SceJeiPlugin"
    ],
    "emi": [
      "org.mateof24.sce.client.emi.SceEmiPlugin"
    ]
  },
  "mixins": [
    "sce.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "1.21.1",
    "java": ">=21",
    "architectury": ">=13.0.8 <14.0.0",
    "fabric-api": "*"
  }
}
