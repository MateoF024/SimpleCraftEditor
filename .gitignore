# MacOS DS_Store files
.DS_Store

# Gradle cache folder
.gradle

# Gradle build folder
build

# IntelliJ
out/
.idea
*.iml
# mpeltonen/sbt-idea plugin
.idea_modules/

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

# Common working directory
run

# Local reference/dependency jars (mods used only for compiling & study)
libs

# Planning docs kept out of the repo
roadmap.md

# Images dropped at the repository root while working — icons, screenshots for the readme, textures on
# their way somewhere else. Every one of them so far has been staged by accident and pushed. Only the
# root is ignored, so docs/ and the mod's own assets stay tracked.
/*.png
/*.jpg
/*.jpeg
